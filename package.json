{
  "name": "happy-sac",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:erp": "turbo run dev --filter=erp",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "typeCheck": "turbo run typeCheck",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
